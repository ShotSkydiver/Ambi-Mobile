    "babel-runtime": "^6.26.0",
    "eslint": "^7.26.0",
    "eslint-config-airbnb": "^18.0.1",
    "eslint-config-airbnb-base": "^14.0.0",
    "eslint-config-prettier": "^8.2.0",
    "eslint-plugin-import": "^2.23.2",

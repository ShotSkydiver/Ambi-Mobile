{
  "name": "ambi",
  "version": "1.5.23",
  "private": true,
  "scripts": {
    "postinstall": "patch-package && (test -n \"$NOYARNPOSTINSTALL\" || yarn postinst-actions)",
    "postinst-actions": "(cd ios && bundle exec pod install) && jetify",
    "start": "react-native start",
    "lint": "eslint App.js index.js ./src ./i18n",
    "eslint:fix": "yarn run lint --fix",
    "eslint-check": "eslint-config-prettier index.js",
    "test": "jest",
    "ios": "react-native run-ios",
    "android": "react-native run-android",
    "android-bundle": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "android-build-apk": "cd android && ./gradlew app:assembleRelease",
    "android-clean": "cd android && ./gradlew clean",
    "android-release": "react-native run-android --variant=release",
    "pack-secrets": "./secrets-scripts/pack-secrets.sh",
    "unpack-secrets": "./secrets-scripts/unpack-secrets.sh",
    "deploy": "./deploy.sh",
    "translate:extract": "format-message extract 'src/**/*.jsx' 'src/**/*.js' 'index.js' 'App.js' -o i18n/locales/en.json -g underscored_crc32"
  },
  "dependencies": {
    "@ambiwork/shared-js": "^1.0.36",
    "@expo/react-native-action-sheet": "^3.9.0",
    "@heap/react-native-heap": "^0.15.0",
